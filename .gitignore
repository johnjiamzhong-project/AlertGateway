# build artifacts
build/

# local Claude Code settings (machine-specific permissions, paths)
.claude/settings.local.json

# board SSH host(s), machine/network-specific — copy board_config.example.json and fill in your own
tools/board_config.json

# vendored prebuilt binaries (Rockchip/proprietary, no redistribution license bundled)
# headers under third_party/*/include are kept, only compiled libs are ignored
third_party/**/*.so
third_party/**/*.so.*

# model weights (large binary, not meant for git history)
model/*.rknn
model/*.onnx
/*.rknn
/*.onnx

# editor/OS noise
.vscode/
.DS_Store

# personal study notes — tracked (interview_qa.md was split into per-topic files under notes/)

# python bytecode
__pycache__/
*.pyc

# generated test/training artifacts (keep local, do not add to Git)
runs/**/*.log
runs/**/*.mp4
runs/**/*.flv
runs/detect/
runs/input_videos/
runs/testsrc2/quality_compare_*/

# IDE/Codex settings
.codex/
