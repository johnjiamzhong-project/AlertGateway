{
  "source": {
    "type": "v4l2",
    "device": "/dev/video20",
    "width": 640,
    "height": 480,
    "fps": 15
  },
  "stream": {
    "rtmp_url": "rtmp://192.168.0.168/live/alertgateway",
    "bitrate_kbps": 3000
  },
  "image_processing": {
    "thumbnail": {
      "enabled": false,
      "width": 320,
      "height": 180,
      "on_detection_only": true
    },
    "roi": {
      "enabled": false,
      "regions": [],
      "filter_outside": true,
      "track_dwell_sec": 0
    },
    "tiling": {
      "enabled": false,
      "grid_cols": 2,
      "grid_rows": 1,
      "overlap_ratio": 0.1,
      "merge_iou_threshold": 0.45
    }
  }
}
